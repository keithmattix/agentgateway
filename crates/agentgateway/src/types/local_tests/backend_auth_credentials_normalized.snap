---
source: crates/agentgateway/src/types/local_tests.rs
assertion_line: 403
description: "Config normalization test for backend_auth_credentials: YAML -> LocalConfig -> NormalizedLocalConfig -> YAML"
---
binds:
  - key: bind/8080
    address: "[::]:8080"
    protocol: http
    tunnelProtocol: direct
    mode: standard
    listeners:
      ns/name/bind/8080/http:
        gatewayName: name
        gatewayNamespace: ns
        hostname: ""
        key: ns/name/bind/8080/http
        listenerName: http
        protocol: HTTP
listener_routes:
  - - ns/name/bind/8080/http
    - - backends:
          - backend: /ns/name/bind/8080/http/default/route0/backend0
            inlinePolicies:
              - backendAuth:
                  credentials:
                    - location:
                        header:
                          name: dd-api-key
                      key: "<redacted>"
                    - location:
                        header:
                          name: dd-application-key
                      key: "<redacted>"
                    - location:
                        header:
                          name: x-auth-token
                          prefix: "Bearer "
                      key: "<redacted>"
            weight: 1
        key: ns/name/bind/8080/http/default/route0
        matches:
          - path:
              pathPrefix: /
        name: route0
        namespace: default
      - backends:
          - backend: /ns/name/bind/8080/http/default/route1/backend0
            inlinePolicies:
              - backendAuth:
                  credentials:
                    - location:
                        header:
                          name: x-auth-email
                      key: "<redacted>"
                  key:
                    value: "<redacted>"
            weight: 1
        key: ns/name/bind/8080/http/default/route1
        matches:
          - path:
              pathPrefix: /
        name: route1
        namespace: default
listener_tcp_routes:
  - - ns/name/bind/8080/http
    - []
policies: []
backends:
  - backend:
      host:
        name: ns/name/bind/8080/http/default/route0/backend0
        namespace: ""
        target: "datadog.example.com:443"
  - backend:
      host:
        name: ns/name/bind/8080/http/default/route1/backend0
        namespace: ""
        target: "combined.example.com:443"
route_groups: []
workloads: []
services: []
